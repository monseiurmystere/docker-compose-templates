# Variables for Redis Stack Server
STACK_CONTAINER_NAME=redis-stack-devel
STACK_PORT_IN=6379
STACK_PORT_OUT=6379
STACK_VOLUME_LOCATION=${HOME}/.docker_debug/redis/data

# Variables for Redis Insight Instance
INSIGHT_CONTAINER_NAME=redis-insight
INSIGHT_PORT_IN=8001
INSIGHT_PORT_OUT=8001
INSIGHT_VOLUME_LOCATION=${HOME}/.docker_debug/redis/insight
